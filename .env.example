# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# TELEGRAM UPLOADER CREDS (Bot API)
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHAT_ID="your-telegram-chat-id"

# GITHUB UPLOADER CREDS (API)
# Gunakan Personal Access Token (Classic) dengan akses "repo"
GITHUB_TOKEN="your-github-personal-access-token"

# Isi GITHUB_REPO HANYA dengan format: "username/nama-repo" 
# CONTOH BENAR: "octocat/Hello-World"
# CONTOH SALAH (JANGAN GUNAKAN LINK): "https://github.com/octocat/Hello-World"
GITHUB_REPO="username/repo-name"
GITHUB_BRANCH="main"
